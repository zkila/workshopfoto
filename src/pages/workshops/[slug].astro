---
import { getEntry, render } from "astro:content";
import MainLayout from "../../layout/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import WorkshopForm from "../../components/WorkshopForm.astro";
import Button from "../../components/ui/Button.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

import { getWorkshop } from "../../lib/workshops";

import {
  countConfirmedRegistrations,
  countWaitlist,
} from "../../lib/registrations";

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing workshop slug");
}

const workshop = await getEntry("workshops", slug);

const workshopDetails = await getWorkshop(slug);

if (!workshop) {
  return new Response("Workshop not found", {
    status: 404,
  });
}

const confirmedRegistrations = await countConfirmedRegistrations(
  workshop.data.slug,
);
const waitlistRegistrations = await countWaitlist(workshop.data.slug);

const { Content } = await render(workshop);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Workshops", href: "/workshops" },
  { label: workshop.data.title },
];
---

<head lang="en">
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
  <meta name="viewport" content="width=device-width" />
  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer></script>
</head>

<MainLayout title={workshop.data.title} breadcrumbs={breadcrumbs}>
  <Container>
    <div class="fixed bottom-8 right-4">
      <a
        href="#workshop-form"
        class="bg-accent/50 backdrop-blur text-white text-xl font-bold py-3 px-6 rounded-full shadow-lg inline-block"
      >
        Register!
      </a>
    </div>
    <div class="p-4 flex flex-col items-center justify-center">
      <h1 class="font-bold text-4xl mb-10">{workshop.data.title}</h1>

      <img
        src={workshop.data.thumbnail}
        alt={workshop.data.title}
        class="aspect-video w-4xl object-cover"
      />

      <div class="p-4">
        <p>{workshop.data.description}</p>
      </div>
    </div>

    <div
      class="w-full md:w-2/3 mx-auto flex flex-col shadow-xs rounded-lg overflow-hidden mb-8"
    >
      <table class="table-fixed">
        <tbody>
          <tr
            class="odd:bg-gray-900 even:bg-neutral-secondary-soft border-b border-gray-700"
          >
            <td class="px-3 py-2"><strong>Date</strong></td>
            <td>: {workshop.data.date}</td>
          </tr>
          <tr
            class="odd:bg-gray-900 even:bg-neutral-secondary-soft border-b border-gray-700"
          >
            <td class="px-3 py-2"><strong>Location</strong></td>
            <td>: {workshop.data.location}</td>
          </tr>
          <tr
            class="odd:bg-gray-900 even:bg-neutral-secondary-soft border-b border-gray-700"
          >
            <td class="px-3 py-2"><strong>Price</strong></td>
            <td
              >: ${workshop.data.priceEarly} (Early Bird) / ${
                workshop.data.priceStandard
              } (Standard)</td
            >
          </tr>
          <tr
            class="odd:bg-gray-900 even:bg-neutral-secondary-soft border-b border-gray-700"
          >
            <td class="px-3 py-2"><strong>Seats</strong></td>
            <td>: {workshop.data.seats}</td>
          </tr>
          <tr
            class="odd:bg-gray-900 even:bg-neutral-secondary-soft border-b border-gray-700"
          >
            <td class="px-3 py-2"><strong>Registration Open</strong></td>
            <td>: {workshopDetails.registration_open ? "Yes" : "No"}</td>
          </tr>
          <tr
            class="odd:bg-gray-900 even:bg-neutral-secondary-soft border-b border-gray-700"
          >
            <td class="px-3 py-2"><strong>Waitlist</strong></td>
            <td>: {waitlistRegistrations}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <hr class="border-gray-500 mb-8" />

    <div
      class="w-full md:w-2/3 mx-auto flex flex-col shadow-xs rounded-lg overflow-hidden mb-8"
    >
      <table class="table-fixed">
        <thead>
          <tr>
            <th class="px-3 py-2">Included</th>
            <th class="px-3 py-2">Not Included</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <td class="px-3 py-2">
              <ul class="list-disc list-inside">
                {workshop.data.included.map((item) => <li>{item}</li>)}
              </ul>
            </td>

            <td class="px-3 py-2">
              <ul class="list-disc list-inside">
                {workshop.data.notIncluded.map((item) => <li>{item}</li>)}
              </ul>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <hr class="border-gray-500" />
    <div class="workshop-content">
      <Content />
    </div>
    <hr class="border-gray-500 mt-8 mb-8" />
    <div class="flex justify-between items-center w-full md:w-1/2 mx-auto">
      <div class="font-bold text-2xl">
        Seats Available: {
          workshop.data.seats - confirmedRegistrations > 0
            ? workshop.data.seats - confirmedRegistrations
            : 0
        }
      </div>
      <div class="font-bold text-2xl">Waitlist: {waitlistRegistrations}</div>
    </div>
    <hr class="border-gray-500 mt-8" />
    <section id="workshop-form">
      <div class="py-8 flex flex-col items-center mx-auto gap-4 justify-center">
        {
          workshopDetails.collab ? (
            <div class="rounded-lg border border-zinc-700 bg-zinc-900 p-6 text-center">
              <h3 class="text-lg font-semibold">Registration via Partner</h3>
              <p class="mt-2 text-zinc-400 mb-2">
                This workshop is organized in collaboration with another
                organization. Please register through the partner's registration
                page.
              </p>
              {workshopDetails.collab_link && (
                <Button href={workshopDetails.collab_link}>
                  Go to Partner's Site
                </Button>
              )}
            </div>
          ) : workshopDetails.registration_open ? (
            <WorkshopForm
              workshopSlug={workshop.id}
              workshopTitle={workshop.data.title}
              availableSeats={workshop.data.seats - confirmedRegistrations}
            />
          ) : (
            <div class="rounded-lg border border-zinc-700 bg-zinc-900 p-6 text-center">
              <h3 class="text-lg font-semibold">Registration Closed</h3>
              <p class="mt-2 text-zinc-400">
                Registration for this workshop is not currently open.
              </p>
            </div>
          )
        }
      </div>
    </section>
  </Container>
</MainLayout>
