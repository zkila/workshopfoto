---
import MainLayout from "../layout/MainLayout.astro";

import Container from "../components/ui/Container.astro";

import Button from "../components/ui/Button.astro";

const heroImage =
  "https://images.throughindonesia.com/assets/general/hero.jpeg";
---

<MainLayout title="Through Indonesia" compactFooter>
  <section
    class="min-h-screen
  flex
  items-center
  bg-cover
  bg-center
  bg-no-repeat"
    style={`background-image: linear-gradient(to left, rgba(0,0,0,0) 0%, rgba(0,0,0,0.85) 100%), url(${heroImage})`}
  >
    <Container>
      <div class="max-w-4xl">
        <h1 class="text-6xl
        md:text-8xl
        mb-8">
          Landscape Photography Workshops & Adventures
        </h1>

        <div
          class="rounded-2xl bg-linear-to-r from-background from-50% to-blue-500/0 p-3 mb-10"
        >
          <p class="text-secondary text-xl">
            Capturing nature's most extraordinary moments.
          </p>
        </div>

        <Button href="/workshops"> Explore our Journeys </Button>
      </div>
    </Container>
  </section>
</MainLayout>
