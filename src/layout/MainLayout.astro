---
import "@fontsource/inter";
import "@fontsource/playfair-display";

import "../styles/global.css";

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const { title, compactFooter } = Astro.props;

interface Props {
  compactFooter?: boolean;
  title: string;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/cam.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body>
    <Navbar />

    <!-- <main
      class="bg-white text-black dark:bg-background dark:text-primary transition-colors duration-300"
    > -->
    <main>
      <slot />
    </main>

    <Footer compact={compactFooter} />
  </body>
</html>

