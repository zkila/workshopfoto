---
interface Props {
  workshopSlug: string;
  workshopTitle: string;
}

import Button from "../components/ui/Button.astro";

const { workshopSlug, workshopTitle } = Astro.props;
---

<form
  id="registration-form"
  class="w-full md:w-2/3 mx-auto flex flex-col gap-3"
  method="POST"
  action="/api/register"
>
  <label class="flex flex-col text-sm flex-1">
    Name
    <input
      type="text"
      name="fullName"
      placeholder="Jane Doe"
      required
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    />
  </label>
  <label class="flex flex-col text-sm flex-1">
    Email
    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      required
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    />
  </label>

  <label class="flex flex-col text-sm flex-1">
    Phone number
    <input
      type="tel"
      name="phone"
      placeholder="123-456-7890"
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    />
  </label>

  <label class="flex flex-col text-sm flex-1">
    Country
    <input
      type="text"
      name="country"
      placeholder="United States"
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    />
  </label>

  <input type="hidden" name="workshopSlug" value={workshopSlug} />

  <input type="hidden" name="workshopTitle" value={workshopTitle} />

  <label class="flex flex-col text-sm flex-1">
    Additional notes
    <textarea
      name="notes"
      placeholder="Tell us more about your interests..."
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    ></textarea>
  </label>
  <div class="border-t border-accent/20 my-1"></div>
  <div
    class="cf-turnstile"
    data-sitekey={import.meta.env.TURNSTILE_SITE_KEY}
    data-callback="enableSubmit"
  >
  </div>
  <Button id="submit-button" type="submit" variant="secondary">Register</Button>
  <p
    id="form-status"
    class="hidden text-sm mt-2 rounded-md p-3"
    aria-live="polite"
  >
  </p>
</form>
<script is:inline>
  window.enableSubmit = function () {
    document.getElementById("submit-button").disabled = false;
  };
</script>
<script>
  (() => {
    console.log("script loaded");

    const form = document.getElementById("registration-form");

    if (!(form instanceof HTMLFormElement)) {
      console.error("Form element not found.");
      return;
    }

    const status = document.getElementById("form-status");

    if (!(status instanceof HTMLParagraphElement)) {
      console.error("Status element not found.");
      return;
    }

    const statusElement = status;

    function showStatus(message: string | null, type: string) {
      statusElement.textContent = message;

      statusElement.classList.remove(
        "hidden",
        "bg-green-900",
        "text-green-200",
        "border",
        "border-green-700",
        "bg-red-900",
        "text-red-200",
        "border-red-700",
      );

      if (type === "success") {
        statusElement.classList.add(
          "bg-green-900",
          "text-green-200",
          "border",
          "border-green-700",
        );
      } else {
        statusElement.classList.add(
          "bg-red-900",
          "text-red-200",
          "border",
          "border-red-700",
        );
      }
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      // console.log(data);

      const submitButton = document.getElementById("submit-button");

      if (!(submitButton instanceof HTMLButtonElement)) {
        console.error("Submit button not found.");
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = "Submitting...";

      const response = await fetch("/api/register", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (!response.ok) {
        showStatus(result.error ?? "Registration failed.", "error");
        return;
      }

      showStatus(
        "Registration submitted! We'll contact you shortly.",
        "success",
      );

      submitButton.disabled = false;
      submitButton.textContent = "Register";

      form.reset();
    });
  })();
</script>
